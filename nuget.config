<?xml version="1.0" encoding="utf-8"?>
<!--
  Solution-level NuGet configuration for CsTool.Logger.

  This file is committed to source control and applies to all developers
  who clone this repository.

  DEVELOPER NOTE - Local Feed:
  The LocalNuGetFeed source below uses a machine-specific path.
  If it does not exist on your machine it will be silently ignored.
  To use a different local feed path, either:
	a) Create the folder C:\Dev\LocalNuGetFeed on your machine, OR
	b) Add your own feed in your global NuGet.Config using Visual Studio:
		 Tools > NuGet Package Manager > Package Manager Settings > Package Sources
	   That setting takes precedence over this file.
-->
<configuration>
  <packageSources>
	<!--
	  Do NOT use <clear /> here - it would block NuGet.org and Visual Studio
	  offline packages on developer machines that don't have a local feed.
	-->

	<!-- Official NuGet feed - always required -->
	<add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />

	<!-- Local development feed for testing CsTool.Logger packages before publishing.
		 Path is machine-specific - ignored if folder does not exist. -->
	<add key="Local NuGet Feed" value="C:\Dev\LocalNuGetFeed" />

	<!-- Visual Studio offline packages - standard VS installation path -->
	<add key="Microsoft Visual Studio Offline Packages"
		 value="C:\Program Files (x86)\Microsoft SDKs\NuGetPackages\" />
  </packageSources>

  <packageRestore>
	<!-- Automatically restore packages on build -->
	<add key="enabled" value="True" />
	<add key="automatic" value="True" />
  </packageRestore>

  <bindingRedirects>
	<add key="skip" value="False" />
  </bindingRedirects>

  <packageManagement>
	<!-- 0 = PackageReference format (SDK-style projects) -->
	<add key="format" value="0" />
	<add key="disabled" value="False" />
  </packageManagement>

  <!--
	Package Source Mapping (NuGet 6.0+)
	Declares which packages are allowed to come from which source.
	This prevents "dependency confusion" attacks where a package with the
	same name published to nuget.org could shadow a private/local package.

	Rules:
	  - More specific prefixes always win over less specific ones.
	  - The wildcard "*" matches everything not claimed by a more specific rule.
	  - ALL packages must be resolvable via at least one mapping when this
		section is present - the "*" on nuget.org acts as the catch-all.
	  - "Local NuGet Feed" is authoritative for all CsTool.* packages so that
		locally built pre-release packages are always preferred over any
		identically named package on nuget.org.
  -->
  <packageSourceMapping>
	<!-- CsTool packages come exclusively from the local development feed.
		 Prevents nuget.org from ever resolving a CsTool.* package. -->
	<packageSource key="Local NuGet Feed">
	  <package pattern="CsTool.*" />
	</packageSource>

	<!-- Everything else comes from nuget.org (catch-all) -->
	<packageSource key="nuget.org">
	  <package pattern="*" />
	</packageSource>
  </packageSourceMapping>

</configuration>
